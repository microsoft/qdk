{
  "name": "qdk-mcp",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "QDK MCP server with circuit visualization",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc --noEmit && cross-env INPUT=circuit-app.html vite build && tsc -p tsconfig.server.json && node build-server.mjs",
    "serve": "bun --watch main.ts",
    "start": "cross-env NODE_ENV=development npm run build && npm run serve"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.24.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "preact": "^10.0.0",
    "qsharp-lang": "file:../npm/qsharp",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "22.10.0",
    "cross-env": "^10.1.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.3.0"
  }
}
