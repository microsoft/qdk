{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "customConditions": ["node"],
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "strict": true,
    "skipLibCheck": true,
    "useDefineForClassFields": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "qsharp-lang/circuit-vis": ["../npm/qsharp/ux/circuit-vis/index.ts"],
      "qsharp-lang/circuit-group": ["../npm/qsharp/src/data-structures/legacyCircuitUpdate.ts"],
      "qsharp-lang/qdk-theme.css": ["../npm/qsharp/ux/qdk-theme.css"],
      "qsharp-lang/qsharp-ux.css": ["../npm/qsharp/ux/qsharp-ux.css"],
      "qsharp-lang/qsharp-circuit.css": ["../npm/qsharp/ux/qsharp-circuit.css"]
    }
  },
  "include": ["src", "server.ts"]
}
