    span: Span
    ty: Type

class SymbolTable:
    def __len__(self) -> int: ...
    def __iter__(self) -> Iterator[Symbol]: ...
    def get(self, id: int) -> Optional[Symbol]: ...
    def lookup(self, name: str) -> Optional[Symbol]: ...

class SemProgram:
