"""Type stubs for the ``qdk_openqasm_parser._native`` extension module."""

from enum import IntEnum
from typing import Any, Iterator, Optional

# ---------------------------------------------------------------------------
# Shared primitives
# ---------------------------------------------------------------------------

class Span:
    lo: int
    hi: int

class Severity(IntEnum):
    Error = ...
    Warning = ...
    Advice = ...

class Label:
    span: Span
    message: Optional[str]

class Diagnostic:
    message: str
    severity: Severity
    code: Optional[str]
    labels: list[Label]
    related: list["Diagnostic"]

class TokenKind:
    @property
    def name(self) -> str: ...
    def __str__(self) -> str: ...

class Token:
    kind: TokenKind
    span: Span

# ---------------------------------------------------------------------------
# Result wrappers
# ---------------------------------------------------------------------------

class ParseResult:
    diagnostics: list[Diagnostic]
    has_errors: bool
    @property
    def program(self) -> "Program": ...

class SemanticResult:
    diagnostics: list[Diagnostic]
    has_errors: bool
    @property
    def program(self) -> "SemProgram": ...
    @property
    def symbols(self) -> "SymbolTable": ...

