{
  "compilerOptions": {
    "moduleResolution": "Bundler",
    "customConditions": ["browser"],
    "isolatedModules": true,
    "esModuleInterop": true,
    "noEmit": true,
    "target": "ES2022",
    "lib": ["ES2022", "WebWorker"],
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["extension.ts", "../**/*.ts"]
}
