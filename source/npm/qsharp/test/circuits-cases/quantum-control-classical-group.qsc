      ],
      "componentGrid": [
        {
          "components": [
            {
              "kind": "measurement",
              "gate": "Measure",
              "qubits": [{ "qubit": 0 }],
              "results": [{ "qubit": 0, "result": 0 }]
            }
          ]
        },
        {
          "components": [
            {
              "kind": "unitary",
              "gate": "if",
              "children": [
