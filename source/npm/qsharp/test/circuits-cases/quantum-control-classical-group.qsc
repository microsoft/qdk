                      "targets": [{ "qubit": 3 }]
                    }
                  ]
                }
              ],
              "targets": [{ "qubit": 2 }, { "qubit": 3 }],
              "controls": [{ "qubit": 1 }, { "qubit": 0, "result": 0 }],
              "isConditional": true
